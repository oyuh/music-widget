# Local development template.
# Copy server values into .env and frontend values into .env.local (both gitignored).
# Bun loads .env/.env.local for the server; Vite (envDir = repo root) loads them for the
# frontend, exposing only VITE_-prefixed vars to the browser.

# --- Hono server (apps/server) -> .env ---
LFM_API_KEY=
LFM_SHARED_SECRET=
REDIS_URL=redis://localhost:6379
# Optional: Postgres for the widget visitor log (which Last.fm usernames use the
# site). Unset = logging is disabled and the endpoint no-ops (fails open).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/applem
# Optional: shared secret guarding POST /api/cron/cleanup (visitor-log
# housekeeping: dedupe + prune stale rows). Point your scheduler at that route
# with `Authorization: Bearer <CRON_SECRET>`. Unset = the route is disabled (503).
CRON_SECRET=
PORT=8787
LOG_LEVEL=info

# --- Frontend (apps/web), public -> .env.local ---
VITE_LFM_KEY=
VITE_LFM_CALLBACK=http://localhost:5173/callback
