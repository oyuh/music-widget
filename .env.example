# Copy to .env.local for Vite development and to Worker secrets for deployed API.

# Vite public values
VITE_LFM_KEY=
VITE_LFM_CALLBACK=http://localhost:8787/callback

# Cloudflare Worker secrets
LFM_API_KEY=
LFM_SHARED_SECRET=

# Railway Redis TCP Proxy URL.
# Example: redis://default:password@shuttle.proxy.rlwy.net:15140
# Use rediss:// only if your Redis proxy is configured for TLS.
REDIS_URL=
