# Copy to apps/server/.env for local server development. Bun auto-loads .env.

# Last.fm credentials (server-only secrets)
LFM_API_KEY=
LFM_SHARED_SECRET=

# Redis connection string.
# Local:   redis://localhost:6379
# Railway: use the Redis service's private URL, e.g.
#          redis://default:password@redis.railway.internal:6379
# REDIS_URL is optional; when unset the server skips caching and calls Last.fm directly.
REDIS_URL=redis://localhost:6379

# HTTP port the server binds. Railway injects PORT automatically.
PORT=8787

# Optional. Directory of the built SvelteKit SPA to serve in production.
# Defaults to ../web/build relative to the server source.
# WEB_DIR=

# debug | info | warn | error
LOG_LEVEL=info
